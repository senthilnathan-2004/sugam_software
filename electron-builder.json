{
  "appId": "com.sugamhms.app",
  "productName": "Sugam HMS",
  "directories": {
    "output": "dist"
  },
  "protocols": {
    "name": "Sugam HMS URL",
    "schemes": [
      "sugamhms"
    ]
  },
  "files": [
    "out/**/*",
    "electron/**/*",
    "node_modules/**/*",
    "prisma/dev.db",
    "package.json"
  ],
  "win": {
    "target": "nsis",
    "icon": "resources/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Sugam HMS"
  },
  "extraResources": [
    {
      "from": "prisma/dev.db",
      "to": "prisma/dev.db"
    }
  ]
}
