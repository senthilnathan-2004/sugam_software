{
  "name": "sugam-hms",
  "version": "1.0.0",
  "description": "Sugam Hospital Management System - Offline-first Desktop App",
  "main": "electron/dist/electron/main.js",
  "scripts": {
    "next:dev": "next dev --turbopack",
    "next:build": "next build",
    "next:start": "next start",
    "next:serve": "npx --yes serve out -l 3000",
    "electron:tsc": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently \"npm run next:dev\" \"wait-on http://localhost:3000 && npm run electron:tsc && electron .\"",
    "prebuild:app": "prisma generate",
    "build:app": "npm run prebuild:app && npm run next:build && npm run electron:tsc",
    "db:prepare-dist": "node scripts/prepare-dist-db.mjs",
    "electron:build": "npm run build:app && npm run db:prepare-dist && electron-builder",
    "electron:dist-win": "npm run build:app && npm run db:prepare-dist && electron-builder --win --x64",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "keywords": [],
  "author": "Sugam HMS Team",
  "license": "Proprietary",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-table": "^8.20.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.15.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "next-themes": "^0.4.4",
    "node-cron": "^4.5.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3",
    "electron-is-dev": "^3.0.1",
    "postcss-loader": "^8.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "wait-on": "^9.0.10"
  }
}
